<!--pages/detail/detail.wxml-->
<view class="page">
  <view class="card" wx:if="{{!loading}}">

    <!-- ========== 查看模式 ========== -->
    <block wx:if="{{!isEditing}}">
      <view class="section">
        <view class="label">标题</view>
        <view class="title {{record.isCompleted ? 'done' : ''}}">{{record.title}}</view>
      </view>
      <view class="section">
        <view class="label">状态</view>
        <view class="status-row">
          <text class="status-tag {{record.isCompleted ? 'done' : 'pending'}}">
            {{record.isCompleted ? '已完成' : '待完成'}}
          </text>
          <text class="time-text" wx:if="{{record.fmtCompletedTime}}">完成于 {{record.fmtCompletedTime}}</text>
        </view>
      </view>
      <view class="section">
        <view class="label">描述</view>
        <view class="desc">{{record.desc || '暂无描述'}}</view>
      </view>

      <!-- 代码块（查看模式） -->
      <view class="section" wx:if="{{record.codeBlocks && record.codeBlocks.length > 0}}">
        <view class="label">代码块</view>
        <view class="code-display-item" wx:for="{{record.codeBlocks}}" wx:key="index" bindtap="onViewFullscreenCode" data-index="{{index}}">
          <view class="code-display-header">
            <text class="code-lang-tag">{{item.language || 'Code'}}</text>
            <text class="code-fullscreen-hint">⛶ 全屏查看</text>
          </view>
          <view class="code-display-content">{{item.content}}</view>
        </view>
      </view>

      <view class="section" wx:if="{{record.tags && record.tags.length > 0}}">
        <view class="label">标签</view>
        <view class="tags-row">
          <text class="tag-badge" wx:for="{{record.tags}}" wx:key="_id" wx:for-item="t">{{t.name || t}}</text>
        </view>
      </view>

      <view class="section">
        <view class="label">创建时间</view>
        <text class="time-text">{{record.fmtCreateTime}}</text>
      </view>

      <view class="actions">
        <button class="action-btn edit-btn" bindtap="onStartEdit">✎ 编辑记录</button>
        <button class="action-btn complete-btn {{record.isCompleted ? 'undo' : ''}}" bindtap="onToggleComplete">
          {{record.isCompleted ? '↩ 撤销完成' : '✓ 标记完成'}}
        </button>
        <button class="action-btn delete-btn" bindtap="onDelete">删除记录</button>
      </view>
    </block>

    <!-- ========== 编辑模式 ========== -->
    <block wx:else>
      <view class="section">
        <view class="label">标题 <text class="required">*</text></view>
        <input class="edit-input" value="{{editForm.title}}" bindinput="onEditTitle" maxlength="50" />
      </view>
      <view class="section">
        <view class="label">描述</view>
        <textarea class="edit-textarea" value="{{editForm.desc}}" bindinput="onEditDesc" auto-height maxlength="200" />
      </view>

      <!-- 代码块（编辑模式） -->
      <view class="section">
        <view class="label">代码块</view>
        <block wx:for="{{editCodeBlocks}}" wx:key="index">
          <view class="code-block-item">
            <view class="code-block-header">
              <scroll-view class="lang-select" scroll-x enhanced show-scrollbar="{{false}}">
                <view
                  class="lang-option {{item.language === lang ? 'active' : ''}}"
                  wx:for="{{languages}}"
                  wx:key="*this"
                  wx:for-item="lang"
                  wx:for-index="langIdx"
                  bindtap="onEditCodeLangChange"
                  data-index="{{index}}"
                  data-lang="{{lang}}"
                >{{lang}}</view>
              </scroll-view>
              <text class="code-fullscreen-btn" bindtap="onEditFullscreenCode" data-index="{{index}}">⛶ 全屏</text>
              <text class="code-remove-btn" bindtap="onEditRemoveCodeBlock" data-index="{{index}}">✕ 删除</text>
            </view>
            <textarea
              class="code-textarea"
              placeholder="在此粘贴代码..."
              value="{{item.content}}"
              bindinput="onEditCodeContentInput"
              data-index="{{index}}"
              auto-height
              maxlength="-1"
            />
          </view>
        </block>
        <view class="code-add-btn" bindtap="onEditAddCodeBlock">+ 添加代码块</view>
      </view>

      <view class="section">
        <view class="label">标签</view>
        <view class="tag-select">
          <view
            class="tag-option {{item.selected ? 'selected' : ''}}"
            wx:for="{{allTags}}"
            wx:key="_id"
            bindtap="onToggleTag"
            data-id="{{item._id}}"
          >{{item.name}}</view>
        </view>
      </view>

      <view class="actions">
        <button class="action-btn save-btn" bindtap="onSaveEdit">✓ 保存修改</button>
        <button class="action-btn cancel-btn" bindtap="onCancelEdit">取消</button>
      </view>
    </block>

  </view>

  <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
</view>
