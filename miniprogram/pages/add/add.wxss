/* pages/add/add.wxss */
.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding: 24rpx;
  box-sizing: border-box;
}

.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.required {
  color: #E53935;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #F5F7FA;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: #4A90D9;
  background: #fff;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #F5F7FA;
  border-radius: 12rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-textarea:focus {
  border-color: #4A90D9;
  background: #fff;
}

/* 标签选择 */
.tag-select {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #F0F2F5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-option.selected {
  color: #fff;
  background: #4A90D9;
  border-color: #4A90D9;
}

.tag-add-btn {
  color: #4A90D9;
  border: 2rpx dashed #4A90D9;
  background: transparent;
}

/* ========== 代码块 ========== */
.code-block-item {
  margin-bottom: 24rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  overflow: hidden;
}

.code-block-header {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #F5F7FA;
  border-bottom: 1rpx solid #E8E8E8;
}

.lang-select {
  flex: 0 0 auto;
  width: calc(100% - 210rpx);
  white-space: nowrap;
}

.lang-option {
  display: inline-block;
  padding: 6rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #888;
  background: #fff;
  border: 1rpx solid #E0E0E0;
}

.lang-option.active {
  color: #fff;
  background: #4A90D9;
  border-color: #4A90D9;
}

.code-fullscreen-btn {
  flex-shrink: 0;
  margin-left: auto;
  margin-right: 12rpx;
  font-size: 22rpx;
  color: #fff;
  background: #4A90D9;
  padding: 8rpx 18rpx;
  border-radius: 6rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.code-remove-btn {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
  background: #E53935;
  padding: 8rpx 18rpx;
  border-radius: 6rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.code-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  font-family: 'Courier New', Consolas, monospace;
  color: #E0E0E0;
  background: #1E1E1E;
  border-radius: 0;
  box-sizing: border-box;
  line-height: 1.6;
}

.code-add-btn {
  display: inline-block;
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  color: #4A90D9;
  border: 2rpx dashed #4A90D9;
  border-radius: 32rpx;
  background: transparent;
  text-align: center;
  margin-top: 12rpx;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  margin-top: 48rpx;
  background: linear-gradient(135deg, #4A90D9, #6BB5FF);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 46rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 217, 0.3);
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn-hover {
  background: linear-gradient(135deg, #3A7BC8, #5AA3EE);
  transform: scale(0.98);
}
