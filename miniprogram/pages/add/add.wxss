/* pages/add/add.wxss */
.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding: 24rpx;
  box-sizing: border-box;
}

.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.required {
  color: #E53935;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #F5F7FA;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: #4A90D9;
  background: #fff;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #F5F7FA;
  border-radius: 12rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-textarea:focus {
  border-color: #4A90D9;
  background: #fff;
}

/* 标签选择 */
.tag-select {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #F0F2F5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-option.selected {
  color: #fff;
  background: #4A90D9;
  border-color: #4A90D9;
}

.tag-add-btn {
  color: #4A90D9;
  border: 2rpx dashed #4A90D9;
  background: transparent;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  margin-top: 48rpx;
  background: linear-gradient(135deg, #4A90D9, #6BB5FF);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 46rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 217, 0.3);
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn-hover {
  background: linear-gradient(135deg, #3A7BC8, #5AA3EE);
  transform: scale(0.98);
}
