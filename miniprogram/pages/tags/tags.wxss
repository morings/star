/* pages/tags/tags.wxss */
.page {
  min-height: 100vh;
  background-color: #F5F7FA;
}

/* 添加栏 */
.add-section {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.add-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #F0F2F5;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.add-btn {
  width: 140rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  background: #4A90D9;
  border-radius: 12rpx;
  flex-shrink: 0;
}

/* 标签列表 */
.tag-list {
  padding: 24rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tag-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag-color-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4A90D9;
}

.tag-name {
  font-size: 30rpx;
  color: #333;
}

.tag-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.action-edit {
  font-size: 26rpx;
  color: #4A90D9;
  padding: 8rpx;
}

.action-delete {
  font-size: 26rpx;
  color: #E53935;
  padding: 8rpx;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #B0B0B0;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
