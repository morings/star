/* pages/index/index.wxss */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F7FA;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #F0F2F5;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #333;
}

.search-icon {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #4A90D9;
  padding: 10rpx 20rpx;
}

/* 状态筛选 */
.status-filter {
  display: flex;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #EEE;
}

.status-item {
  padding: 8rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #F0F2F5;
  transition: all 0.2s;
}

.status-item.active {
  color: #fff;
}

.status-item.active:nth-child(1) { background: #4A90D9; }
.status-item.active:nth-child(2) { background: #F5A623; }
.status-item.active:nth-child(3) { background: #4CAF50; }

/* 完成时间筛选 */
.time-filter {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #EEE;
}

.time-picker {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  margin-right: 16rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  background: #F8F9FB;
  font-size: 24rpx;
}

.time-label {
  color: #888;
}

.time-val {
  color: #333;
  margin-left: 6rpx;
}

.time-confirm {
  font-size: 26rpx;
  color: #4A90D9;
  padding: 10rpx 20rpx;
  font-weight: 500;
}

.time-clear {
  font-size: 26rpx;
  color: #999;
  padding: 10rpx 20rpx;
  margin-left: 8rpx;
}

/* 标签筛选 */
.tag-filter {
  display: flex;
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #EEE;
}

.tag-filter-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #F0F2F5;
  transition: all 0.2s;
}

.tag-filter-item.active {
  color: #fff;
  background: #4A90D9;
}

/* 记录列表 */
.record-list {
  flex: 1;
  padding: 20rpx 24rpx;
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.record-card.done {
  opacity: 0.7;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-card.done .card-title {
  text-decoration: line-through;
  color: #999;
}

.card-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.s-pending {
  color: #F5A623;
  background: #FFF8E1;
}

.s-done {
  color: #4CAF50;
  background: #E8F5E9;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.tag-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #4A90D9;
  background: #EBF3FD;
}

.card-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-time {
  font-size: 22rpx;
  color: #B0B0B0;
}

.card-arrow {
  font-size: 32rpx;
  color: #CCC;
  font-weight: 300;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #B0B0B0;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.loading-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #B0B0B0;
  font-size: 28rpx;
}
